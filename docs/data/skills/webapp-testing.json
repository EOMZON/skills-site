{
  "schema_version": "1.0.0",
  "id": "webapp-testing",
  "title": "Webapp Testing",
  "summary": "用 Playwright 验证本地 Web 应用行为，适合交互验收、回归检查、截图取证与 UI 调试。",
  "scene": "website-frontend",
  "subscenes": [
    "ui-testing",
    "playwright",
    "local-debugging"
  ],
  "keywords": [
    "playwright",
    "testing",
    "webapp",
    "ui",
    "browser",
    "screenshot",
    "frontend"
  ],
  "invoke": "$webapp-testing",
  "use_when": [
    "需要验证本地网页或前端交互",
    "需要复现 bug、截图取证或查看浏览器日志",
    "需要在真实浏览器里走一遍关键流程"
  ],
  "avoid_when": [
    "只是阅读静态源码而不需要运行页面",
    "不是 Web 界面相关问题"
  ],
  "inputs": [
    {
      "name": "app_url_or_path",
      "required": true,
      "description": "待验证的本地地址、页面入口或运行方式"
    },
    {
      "name": "verification_goal",
      "required": false,
      "description": "要检查的关键流程、问题现象或验收标准"
    }
  ],
  "returns": [
    "浏览器内的验证结论",
    "截图、日志或复现证据",
    "可复跑的自动化步骤"
  ],
  "dependencies": {
    "bins": [
      "playwright",
      "python3"
    ],
    "services": [],
    "stateful": true
  },
  "related_ids": [
    "frontend-design",
    "vercel-deploy"
  ],
  "stability": "stable",
  "visibility": "public",
  "updated_at": "2026-03-24",
